<%- include("partials/head",{title:"Edit Report"}) %>

<%- include("partials/navbar") %>

<section class="page-header">

    <h1>Edit Report</h1>

    <p>Update your report details.</p>

</section>

<section class="report-container">

    <form
        action="/edit/<%= item._id %>"
        method="POST"
        enctype="multipart/form-data"
        class="report-form">

        <label>Item Status</label>

        <select name="itemType">

            <option value="Lost" <%= item.itemType==="Lost"?"selected":"" %>>
                Lost
            </option>

            <option value="Found" <%= item.itemType==="Found"?"selected":"" %>>
                Found
            </option>

        </select>

        <label>Item Name</label>

        <input
            type="text"
            name="itemName"
            value="<%= item.itemName %>"
            required>

        <label>Category</label>

        <input
            type="text"
            name="category"
            value="<%= item.category %>"
            required>

        <label>Location</label>

        <input
            type="text"
            name="location"
            value="<%= item.location %>"
            required>

        <label>Description</label>

        <textarea
            name="description"
            rows="5"
            required><%= item.description %></textarea>

        <% if(item.image){ %>

            <label>Current Image</label>

            <img
                src="/uploads/<%= item.image %>"
                alt="Current Image"
                class="item-image">

        <% } %>

        <label>Update Image</label>

        <input
            type="file"
            name="image"
            accept="image/*">

        <button class="btn-green">
            Update Report
        </button>

    </form>

</section>

<%- include("partials/footer") %>

