<nav class="navbar">

    <div class="logo">
        <a href="/" class="logo-link">
            <img src="/images/logo.png" alt="Yoink Logo">

            <h2>
                <span class="logo-black">Yoink</span><span class="logo-green">!</span>
            </h2>
        </a>
    </div>

    <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/browse">Browse</a></li>
        <li><a href="/report">Report</a></li>
        <li><a href="/my-reports">My Reports</a></li>
    </ul>

    <% if(user){ %>

        <div class="profile-dropdown">

            <button class="profile-btn">

                <img
                    src="<%= user.photo %>"
                    alt="<%= user.displayName %>"
                    class="profile-pic">

                <span><%= user.displayName %></span>

            </button>

            <div class="dropdown-content">

                <div class="profile-info">

                    <img
                        src="<%= user.photo %>"
                        class="profile-large">

                    <h4><%= user.displayName %></h4>

                    <p><%= user.email %></p>

                </div>

                <hr>

                <a href="/my-reports">📄 My Reports</a>

                <a href="/report">➕ Report Item</a>

                <a href="/auth/logout">🚪 Logout</a>

            </div>

        </div>

    <% } else { %>

        <a href="/auth/google" class="login-btn">
            Login with Google
        </a>

    <% } %>

</nav>